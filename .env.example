# Supabase Postgres — pooled connection for runtime queries
DATABASE_URL=

# Supabase Postgres — direct connection for Prisma migrations
DIRECT_URL=

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Full URL of your app (http://localhost:3000 for local dev)
NEXTAUTH_URL=

# From Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER-SIDE ONLY, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=
